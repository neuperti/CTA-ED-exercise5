zara <- gutenberg_download(1998, meta_fields = "title")
# dividing into parts manually by part headings
all_mentions <- which(zara$text == "FIRST PART")
actual_start <- all_mentions[2]
zara_parts <- zara %>%
slice(actual_start:n()) %>%
mutate(part_num = cumsum(str_detect(text, "^FIRST PART$|^SECOND PART$|^THIRD PART$|^FOURTH AND FINAL PART$|^APPENDIX$")))
